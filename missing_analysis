"""missing_analysis.py  Funzioni per la caratterizzazione del missing data in registri clinici. Fase 1 del paper: MCAR test, analisi MAR/MNAR, pattern di missingness.  Uso:     from src.missing_analysis import littles_mcar_test, classify_mar_mnar """  import numpy as np import pandas as pd from scipy.stats import chi2 from sklearn.linear_model import LogisticRegression from sklearn.metrics import roc_auc_score from sklearn.impute import SimpleImputer   def compute_missingness_summary(df: pd.DataFrame,                                 target: str) -> pd.DataFrame:     """Calcola statistiche di missingness per ogni variabile.      Args:         df: DataFrame con i dati clinici.         target: Nome della variabile target (es. 'LVEF').      Returns:         DataFrame con colonne: variabile, n_mancanti, pct_mancanti,         n_LVEF_low, n_LVEF_high, p_differenza.     """     rows = []     for col in df.columns:         if col == target:             continue         n_miss = df[col].isna().sum()         pct = n_miss / len(df) * 100         low  = df[df[target] < 50][col].dropna()         high = df[df[target] >= 50][col].dropna()         try:             from scipy.stats import mannwhitneyu             _, pval = mannwhitneyu(low, high, alternative='two-sided')         except Exception:             pval = float('nan')         rows.append({             'variabile': col,             'n_mancanti': n_miss,             'pct_mancanti': round(pct, 1),             'n_LVEF_low': len(low),             'n_LVEF_high': len(high),             'p_differenza': round(pval, 4) if not pd.isna(pval) else 'NA'         })     return pd.DataFrame(rows).sort_values('pct_mancanti', ascending=False)   def littles_mcar_test(df: pd.DataFrame) -> tuple:     """Test MCAR di Little per dati numerici con missing values.      Verifica H0: i dati sono Missing Completely At Random.     Un p-value < 0.05 rigetta MCAR.      Args:         df: DataFrame con sole variabili numeriche contenenti NaN.      Returns:         Tupla (chi2_statistic, degrees_of_freedom, p_value).     """     cols = df.columns     grand_mean = df.mean()     grand_cov  = df.cov()     patterns = df.isna().apply(lambda r: tuple(r), axis=1)     d2, dof = 0.0, 0     for pat, grp in df.groupby(patterns):         obs_cols = [cols[i] for i, m in enumerate(pat) if not m]         if len(obs_cols) < 2:             continue         grp_obs = grp[obs_cols].dropna()         if len(grp_obs) < 2:             continue         mu_j   = grand_mean[obs_cols].values         xbar_j = grp_obs.mean().values         cov_j  = grand_cov.loc[obs_cols, obs_cols].values         try:             inv_cov = np.linalg.inv(cov_j)             diff = xbar_j - mu_j             d2  += len(grp_obs) * float(diff @ inv_cov @ diff)             dof += len(obs_cols)
